pipeline {
    agent any

    environment {
        APP_DIR = "app/frontend"
        SONAR_SCANNER = tool 'sonar-scanner'
    }

    stages {

        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Detect Frontend Changes') {
            steps {
                script {

                    def changedFiles = sh(
                        script: "git diff --name-only HEAD~1 HEAD",
                        returnStdout: true
                    ).trim()

                    echo "Changed Files:"
                    echo changedFiles

                    if (!changedFiles.contains("app/frontend/")) {

                        currentBuild.result = 'NOT_BUILT'

                        error("No frontend changes detected. Skipping pipeline.")
                    }
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {

                dir("${APP_DIR}") {

                    withSonarQubeEnv('sonar-server') {

                        sh """
                            ${SONAR_SCANNER}/bin/sonar-scanner \
                            -Dsonar.projectKey=frontend-app \
                            -Dsonar.projectName=frontend-app \
                            -Dsonar.sources=. \
                            -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info
                        """
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {

                timeout(time: 5, unit: 'MINUTES') {

                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Trivy Filesystem Scan') {
            steps {

                dir("${APP_DIR}") {

                    sh '''
                        trivy fs . > trivy-fs-report.txt
                    '''
                }
            }
        }

        stage('Verify Frontend Folder') {
            steps {
                sh 'ls -la app/frontend'
            }
        }

        stage('Build Frontend Docker Image') {
            steps {

                sh '''
                    docker build -t frontend-app:latest \
                    -f app/frontend/Dockerfile \
                    app/frontend
                '''
            }
        }

        stage('Trivy Docker Image Scan') {
            steps {

                sh '''
                    trivy image frontend-app:latest > trivy-image-report.txt
                '''
            }
        }

        stage('Frontend Docker Images') {
            steps {
                sh 'docker images'
            }
        }
    }

    post {

        success {
            echo 'Frontend Pipeline Completed Successfully'
        }

        failure {
            echo 'Frontend Pipeline Failed'
        }
    }
}
