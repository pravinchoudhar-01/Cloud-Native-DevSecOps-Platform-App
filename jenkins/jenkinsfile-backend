pipeline {

    agent any

    environment {

        APP_DIR = "app/backend"

        SONAR_SCANNER = tool 'sonar-scanner'

        AWS_REGION = "us-east-1"

        ECR_REPO = "backend-app"

        AWS_ACCOUNT_ID = "975049914104"

        ECR_URI = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
    }

    stages {

        stage('Checkout Code') {

            steps {

                checkout scm
            }
        }

        stage('Detect Backend Changes') {

            steps {

                script {

                    def changedFiles = sh(
                        script: "git diff --name-only HEAD~1 HEAD",
                        returnStdout: true
                    ).trim()

                    echo "Changed Files:"
                    echo changedFiles

                    if (!changedFiles.contains("app/backend/")) {

                        currentBuild.result = 'NOT_BUILT'

                        error("No backend changes detected. Skipping pipeline.")
                    }
                }
            }
        }

        stage('SonarQube Analysis') {

            steps {

                dir("${APP_DIR}") {

                    withSonarQubeEnv('sonar-server') {

                        sh """
                            ${SONAR_SCANNER}/bin/sonar-scanner \
                            -Dsonar.projectKey=backend-app \
                            -Dsonar.projectName=backend-app \
                            -Dsonar.sources=. \
                            -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info
                        """
                    }
                }
            }
        }

        stage('Quality Gate') {

            steps {

                timeout(time: 5, unit: 'MINUTES') {

                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Trivy Filesystem Scan') {

            steps {

                dir("${APP_DIR}") {

                    sh '''
                        trivy fs . > trivy-fs-report.txt
                    '''
                }
            }
        }

        stage('Verify Backend Folder') {

            steps {

                sh 'ls -la app/backend'
            }
        }

        stage('Build Backend Docker Image') {

            steps {

                sh '''
                    docker build -t backend-app:${BUILD_NUMBER} \
                    -f app/backend/Dockerfile \
                    app/backend
                '''
            }
        }

        stage('Trivy Docker Image Scan') {

            steps {

                sh '''
                    trivy image backend-app:${BUILD_NUMBER} > trivy-image-report.txt
                '''
            }
        }

        stage('Login To AWS ECR') {

            steps {

                withCredentials([
                    string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) {

                    sh '''
                        export AWS_ACCESS_KEY_ID=$AWS_ACCESS_KEY_ID
                        export AWS_SECRET_ACCESS_KEY=$AWS_SECRET_ACCESS_KEY

                        aws ecr get-login-password --region ${AWS_REGION} | \
                        docker login --username AWS --password-stdin ${ECR_URI}
                    '''
                }
            }
        }

        stage('Tag Docker Image') {

            steps {

                sh '''
                    docker tag backend-app:${BUILD_NUMBER} \
                    ${ECR_URI}/${ECR_REPO}:${BUILD_NUMBER}
                '''
            }
        }

        stage('Push Docker Image To ECR') {

            steps {

                sh '''
                    docker push ${ECR_URI}/${ECR_REPO}:${BUILD_NUMBER}
                '''
            }
        }

        stage('Backend Docker Images') {

            steps {

                sh 'docker images'
            }
        }
    }

    post {

        success {

            echo 'Backend Pipeline Completed Successfully'
        }

        failure {

            echo 'Backend Pipeline Failed'
        }
    }
}
